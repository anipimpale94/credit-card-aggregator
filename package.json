{
  "name": "credit-card-aggregator",
  "version": "1.0.0",
  "description": "Track credit card usage and budgets across multiple cards",
  "main": "public/main.js",
  "homepage": "./",
  "scripts": {
    "react-start": "cd src && npm start",
    "react-build": "cd src && npm run build",
    "server-start": "cd server && npm start",
    "server-dev": "cd server && npm run dev",
    "electron-start": "wait-on http://localhost:3000 && electron .",
    "start": "concurrently \"npm run react-start\" \"npm run server-start\"",
    "dev": "concurrently \"npm run react-start\" \"npm run server-dev\"",
    "build": "npm run react-build && npm run server-build",
    "electron-dev": "concurrently \"npm run react-start\" \"npm run server-dev\" \"wait-on http://localhost:3000 && electron .\"",
    "pack": "electron-builder --dir",
    "dist": "npm run react-build && electron-builder"
  },
  "dependencies": {
    "concurrently": "^8.2.2",
    "electron-squirrel-startup": "^1.1.1",
    "electron-is-dev": "^2.0.0",
    "wait-on": "^7.0.1"
  },
  "devDependencies": {
    "electron": "^27.0.0",
    "electron-builder": "^24.6.4"
  }
}
